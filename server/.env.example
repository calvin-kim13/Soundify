# ---- Soundify server environment (example) ----
# Copy to .env and fill in real values. Do not commit .env.

# MongoDB Atlas connection string
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/soundify?retryWrites=true&w=majority

# Port the API/GraphQL server listens on (client proxies here)
PORT=4000

# JWT signing secret — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ---- File storage: local disk ----
# Uploaded songs/covers are saved to server/uploads and served at /uploads.
# SERVER_URL is the base URL used to build playable links. Defaults to
# http://localhost:PORT — only set this if the server is reachable elsewhere.
# SERVER_URL=http://localhost:4000
